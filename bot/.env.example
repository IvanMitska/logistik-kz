# ─── Telegram bot ──────────────────────────────────────────────────────────
# Token from @BotFather (/newbot)
BOT_TOKEN=123456:ABC-DEF...

# Chat where leads are delivered. For a managers GROUP, add the bot to the
# group, send any message, then read the negative chat id (e.g. -1001234567890).
# Tip: temporarily set LOG_UPDATES=1 to print incoming chat ids to the console.
MANAGERS_CHAT_ID=-1001234567890

# Public HTTPS URL of the mini-app (Telegram requires HTTPS).
# In dev you can tunnel the local server, e.g. with cloudflared / ngrok.
MINIAPP_URL=https://your-domain.example/app

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8787
# Public base URL of THIS bot server (used for webhook mode). Leave empty to
# use long polling (simplest for local dev).
PUBLIC_URL=
# Where to store the orders JSON file.
DATA_DIR=./data

# Set to 1 to log raw updates (handy to discover your MANAGERS_CHAT_ID).
LOG_UPDATES=0
